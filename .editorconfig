# ==========================================
# AI Master - EditorConfig
# ==========================================

# EditorConfig is awesome: https://editorconfig.org

root = true

# -------------------------------------------------
# Default settings for all files
# -------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# -------------------------------------------------
# Markdown
# -------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# -------------------------------------------------
# YAML
# -------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# -------------------------------------------------
# JSON
# -------------------------------------------------
[*.json]
indent_size = 2

# -------------------------------------------------
# XML
# -------------------------------------------------
[*.xml]
indent_size = 2

# -------------------------------------------------
# HTML
# -------------------------------------------------
[*.html]
indent_size = 2

# -------------------------------------------------
# CSS
# -------------------------------------------------
[*.css]
indent_size = 2

# -------------------------------------------------
# JavaScript
# -------------------------------------------------
[*.js]
indent_size = 2

# -------------------------------------------------
# TypeScript
# -------------------------------------------------
[*.ts]
indent_size = 2

# -------------------------------------------------
# Python
# -------------------------------------------------
[*.py]
indent_size = 4

# -------------------------------------------------
# Shell Scripts
# -------------------------------------------------
[*.sh]
indent_size = 4

# -------------------------------------------------
# Dockerfile
# -------------------------------------------------
[Dockerfile]
indent_size = 4

# -------------------------------------------------
# Windows Batch
# -------------------------------------------------
[*.bat]
end_of_line = crlf

# -------------------------------------------------
# PowerShell
# -------------------------------------------------
[*.ps1]
end_of_line = crlf

# -------------------------------------------------
# GitHub Workflows
# -------------------------------------------------
[.github/workflows/*]
indent_size = 2
