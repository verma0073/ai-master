# ==========================================
# AI Master - Git Attributes
# ==========================================

# Auto detect text files
* text=auto

# ------------------------------------------
# Documentation
# ------------------------------------------

*.md text eol=lf
*.txt text eol=lf

# ------------------------------------------
# Python
# ------------------------------------------

*.py text eol=lf

# ------------------------------------------
# YAML
# ------------------------------------------

*.yml text eol=lf
*.yaml text eol=lf

# ------------------------------------------
# JSON
# ------------------------------------------

*.json text eol=lf

# ------------------------------------------
# Shell Scripts
# ------------------------------------------

*.sh text eol=lf

# ------------------------------------------
# Docker
# ------------------------------------------

Dockerfile text eol=lf
*.dockerfile text eol=lf

# ------------------------------------------
# PowerShell
# ------------------------------------------

*.ps1 text eol=crlf

# ------------------------------------------
# Windows Batch
# ------------------------------------------

*.bat text eol=crlf

# ------------------------------------------
# Images
# ------------------------------------------

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text

# ------------------------------------------
# PDF
# ------------------------------------------

*.pdf binary

# ------------------------------------------
# ZIP
# ------------------------------------------

*.zip binary

# ------------------------------------------
# Model Files
# ------------------------------------------

*.onnx binary
*.bin binary
*.pt binary
*.pth binary

# ------------------------------------------
# Notebooks
# ------------------------------------------

*.ipynb text
